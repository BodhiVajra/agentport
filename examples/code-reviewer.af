{
  "version": "1.0",
  "metadata": {
    "name": "code-reviewer",
    "description": "AI-powered code reviewer for pull requests - specializes in Python, JavaScript, and TypeScript",
    "version": "1.0.0",
    "author": "AgentPort Team",
    "tags": [
      "code-review",
      "developer-tools",
      "ai",
      "pull-request"
    ],
    "created_at": "2025-01-15T10:00:00Z",
    "updated_at": "2025-01-15T10:00:00Z"
  },
  "state": {
    "model_config": {
      "provider": "openai",
      "model": "gpt-4",
      "model_kwargs": {
        "top_p": 0.9
      },
      "temperature": 0.5,
      "max_tokens": 4096
    },
    "system_prompt": "You are an expert code reviewer specializing in Python, JavaScript, and TypeScript.\n\nYour role is to analyze code changes and provide constructive feedback on:\n- Code quality and best practices (PEP 8, ESLint rules)\n- Potential bugs and edge cases\n- Security vulnerabilities (OWASP guidelines)\n- Performance improvements\n- Code readability and maintainability\n- Test coverage and quality\n\nFor each review, you must:\n1. Identify the file and specific lines being reviewed\n2. Categorize issues by severity: Critical, Major, Minor, Suggestion\n3. Provide actionable fixes with code examples when possible\n4. Explain why the change is problematic and what the recommended approach is\n\nAlways be constructive and professional. Focus on helping developers improve, not criticizing.",
    "tools": [
      {
        "id": "tool_review_code",
        "name": "review_code",
        "description": "Review code changes and provide structured feedback",
        "type": "function",
        "code": "def review_code(file_path: str, changes: str) -> dict:\n    \"\"\"Review code changes and return feedback.\"\"\"\n    # Implementation would analyze the diff\n    pass",
        "arguments": [
          {
            "name": "file_path",
            "type": "string",
            "description": "Path to the file being reviewed",
            "required": true
          },
          {
            "name": "changes",
            "type": "string",
            "description": "Diff or patch content to review",
            "required": true
          },
          {
            "name": "language",
            "type": "string",
            "description": "Programming language (python, javascript, typescript)",
            "required": false,
            "enum": ["python", "javascript", "typescript", "go", "rust", "java"]
          }
        ],
        "output_schema": {
          "type": "object",
          "properties": {
            "file": {"type": "string"},
            "issues": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "severity": {"type": "string", "enum": ["critical", "major", "minor", "suggestion"]},
                  "line": {"type": "integer"},
                  "message": {"type": "string"},
                  "suggestion": {"type": "string"}
                }
              }
            }
          }
        },
        "enabled": true
      },
      {
        "id": "tool_check_security",
        "name": "check_security",
        "description": "Check for common security vulnerabilities",
        "type": "function",
        "code": "def check_security(code: str) -> dict:\n    \"\"\"Scan code for security issues.\"\"\"\n    pass",
        "arguments": [
          {
            "name": "code",
            "type": "string",
            "description": "Code to scan for security issues",
            "required": true
          }
        ],
        "enabled": true
      },
      {
        "id": "tool_suggest_tests",
        "name": "suggest_tests",
        "description": "Suggest unit tests for the changed code",
        "type": "function",
        "arguments": [
          {
            "name": "file_path",
            "type": "string",
            "description": "Path to the file to generate tests for",
            "required": true
          },
          {
            "name": "function_name",
            "type": "string",
            "description": "Name of the function to test",
            "required": false
          }
        ],
        "enabled": true
      }
    ],
    "tool_rules": [
      {
        "rule_type": "always",
        "tool_name": "review_code",
        "condition": "Every PR must be reviewed",
        "description": "Mandatory code review for all pull requests"
      },
      {
        "rule_type": "always",
        "tool_name": "check_security",
        "condition": "All new code must pass security scan",
        "description": "Security check is required before merge"
      }
    ],
    "memory_blocks": [
      {
        "id": "block_persona",
        "label": "persona",
        "text": "You are a senior software engineer with 10+ years of experience. You have deep knowledge of secure coding practices, design patterns, and software architecture. You provide detailed, educational feedback that helps developers grow.",
        "enabled": true,
        "in_context": true,
        "metadata": {
          "priority": "high"
        }
      },
      {
        "id": "block_guidelines",
        "label": "system",
        "text": "Review Guidelines:\n- Critical: Security bugs, memory leaks, crashes\n- Major: Logic errors, performance issues, missing error handling\n- Minor: Style violations, minor optimizations\n- Suggestion: Improvements that are nice to have\n\nAlways prioritize functional correctness and security over style.",
        "enabled": true,
        "in_context": true,
        "metadata": {}
      },
      {
        "id": "block_context",
        "label": "human",
        "text": "This is a code review for a pull request in a Python/TypeScript project. The team follows best practices and expects high-quality code.",
        "enabled": true,
        "in_context": true,
        "metadata": {
          "context": "pr_review"
        }
      }
    ],
    "message_history": [],
    "env_vars": [
      {
        "name": "GITHUB_TOKEN",
        "value": "",
        "description": "GitHub token for accessing PR metadata",
        "secret": true
      },
      {
        "name": "OPENAI_API_KEY",
        "value": "",
        "description": "OpenAI API key for GPT-4",
        "secret": true
      }
    ]
  }
}
